# Database
DATABASE_URL=postgresql://username:password@localhost:5432/ai_governance

# Redis (for Celery workers)
REDIS_URL=redis://localhost:6379/0

# Logging
LOG_LEVEL=INFO

# CORS (comma-separated origins, or * for all)
CORS_ORIGINS=http://localhost:3000

# Alert thresholds
ALERT_COST_THRESHOLD=50.0
ALERT_DATA_OUT_THRESHOLD_MB=10.0
ALERT_USAGE_SPIKE_PERCENT=30.0
ALERT_TOKEN_THRESHOLD=10000

# Frontend URL (used for CORS / redirects)
FRONTEND_URL=http://localhost:3000

# ----------------------------------------------------------------------------
# Dropdown / lookup defaults — comma-separated. These are MERGED with values
# already present in the database. Leave empty to drive purely from DB rows.
# ----------------------------------------------------------------------------
LOOKUP_AUTH_TYPES=API Key,OAuth,Basic Auth,Service Account,Bearer Token
LOOKUP_INGESTION_MODES=api,webhook,stream,batch,agent
LOOKUP_CONNECTOR_STATUSES=active,paused,disabled,error
LOOKUP_TOOL_TYPES=LLM,Infra,Vector DB,External API,ML Model,Agent,Cache,Worker
LOOKUP_PROVIDERS=OpenAI,Anthropic,Google,Azure,AWS,Cohere,HuggingFace,Mistral
LOOKUP_RULE_METRICS=cost,tokens,latency,error_rate,requests,risk_score,anomaly_score,data_out_mb
LOOKUP_RULE_SCOPES=organization,project,user,api_key,tool
LOOKUP_RULE_OPERATORS=>,>=,<,<=,==,!=
LOOKUP_SEVERITIES=critical,high,medium,low
LOOKUP_EVENT_STATUSES=success,completed,failed,error,timeout
LOOKUP_PLAN_TYPES=free,starter,pro,enterprise
LOOKUP_ENVIRONMENTS=development,staging,production
LOOKUP_BUDGET_PERIODS=daily,monthly,quarterly,yearly
